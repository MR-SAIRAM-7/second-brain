# App-level ignore file (recommended if git is initialized in /app)

# Dependencies
node_modules/
server/node_modules/

# Build outputs
dist/
.vite/
server/dist/
server/build/

# Coverage and cache
coverage/
server/coverage/
server/.nyc_output/
*.tsbuildinfo

# Environment files
.env
.env.*
!.env.example
server/.env
server/.env.*
!server/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor settings
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
