# Server Port
PORT=3001

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/secondbrain

# Comma-separated allowed frontend origins for CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# OpenAI API Key for Summarization and Tagging
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model used for summarization/tag extraction
OPENAI_MODEL=gpt-4o-mini

# Cloudinary Config for File Uploads
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
